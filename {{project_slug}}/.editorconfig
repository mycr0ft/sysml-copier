root = true

[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4

[*.sysml]
indent_style = space
indent_size = 4

[*.kerml]
indent_style = space
indent_size = 4

[*.md]
trim_trailing_whitespace = true
max_line_length = off

[*.{yaml,yml}]
indent_style = space
indent_size = 2

[*.{json,toml}]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
